Problem: Rotate Linked List Right by k Places - Implement using linked list with dynamic memory allocation.

#include <stdio.h>
#include <stdlib.h>

struct Node 
{
    int data;
    struct Node* next;
};

void rotateRight(struct Node** head_ref, int k, int n) {
    if (*head_ref == NULL || k == 0 || n == 0) return;

    // 1. Normalize k in case k > n
    k = k % n;
    if (k == 0) return;

    // 2. Find the current tail and connect it to head
    struct Node* tail = *head_ref;
    while (tail->next != NULL) {
        tail = tail->next;
    }
    tail->next = *head_ref; // Make it circular

    // 3. Traverse to the (n-k)th node
    struct Node* newTail = *head_ref;
    for (int i = 0; i < n - k - 1; i++) {
        newTail = newTail->next;
    }

    // 4. Update the new head and break the circle
    *head_ref = newTail->next;
    newTail->next = NULL;
}

int main() {
    int n, k, val;
    struct Node *head = NULL, *tail = NULL;

    if (scanf("%d", &n) != 1) return 0;

    for (int i = 0; i < n; i++) {
        scanf("%d", &val);
        struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
        newNode->data = val; newNode->next = NULL;
        if (!head) head = tail = newNode;
        else { tail->next = newNode; tail = newNode; }
    }

    scanf("%d", &k);
    rotateRight(&head, k, n);

    // Print result
    struct Node* temp = head;
    while (temp) {
        printf("%d%s", temp->data, temp->next ? " " : "");
        temp = temp->next;
    }

    return 0;
}
