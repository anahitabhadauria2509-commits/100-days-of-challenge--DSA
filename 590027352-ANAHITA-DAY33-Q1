Problem: Convert an infix expression to postfix notation using stack.

#include <stdio.h>
#include <ctype.h>

// Function to define operator precedence
int prec(char c) {
    if (c == '^') return 3;
    if (c == '*' || c == '/') return 2;
    if (c == '+' || c == '-') return 1;
    return -1;
}

int main() {
    char s[100], stack[100];
    int top = -1;
    scanf("%s", s);

    for (int i = 0; s[i] != '\0'; i++) {
        char c = s[i];

        // 1. If operand, print it
        if (isalnum(c)) {
            printf("%c", c);
        }
        // 2. If '(', push to stack
        else if (c == '(') {
            stack[++top] = '(';
        }
        // 3. If ')', pop until '(' is found
        else if (c == ')') {
            while (top != -1 && stack[top] != '(')
                printf("%c", stack[top--]);
            top--; // pop '('
        }
        // 4. If operator
        else {
            while (top != -1 && prec(c) <= prec(stack[top])) {
                printf("%c", stack[top--]);
            }
            stack[++top] = c;
        }
    }

    // 5. Pop remaining operators
    while (top != -1) {
        printf("%c", stack[top--]);
    }

    return 0;
}
