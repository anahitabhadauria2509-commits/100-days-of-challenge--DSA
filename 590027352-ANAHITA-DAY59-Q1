#include <stdio.h>
#include <stdlib.h>

struct Node {
    int data;
    struct Node *left, *right;
};

struct Node* newNode(int data) {
    struct Node* node = (struct Node*)malloc(sizeof(struct Node));
    node->data = data;
    node->left = node->right = NULL;
    return node;
}

int search(int arr[], int strt, int end, int value) {
    for (int i = strt; i <= end; i++) {
        if (arr[i] == value) return i;
    }
    return -1;
}

// Build tree from Inorder and Postorder
struct Node* buildTree(int in[], int post[], int inStrt, int inEnd, int* postIdx) {
    if (inStrt > inEnd) return NULL;

    // Pick current node from postorder traversal using postIdx
    struct Node* tNode = newNode(post[(*postIdx)--]);

    if (inStrt == inEnd) return tNode;

    int inIdx = search(in, inStrt, inEnd, tNode->data);

    // IMPORTANT: Build right subtree before left subtree
    tNode->right = buildTree(in, post, inIdx + 1, inEnd, postIdx);
    tNode->left = buildTree(in, post, inStrt, inIdx - 1, postIdx);

    return tNode;
}

void printPreorder(struct Node* node) {
    if (node == NULL) return;
    printf("%d ", node->data);
    printPreorder(node->left);
    printPreorder(node->right);
}

int main() {
    int n;
    if (scanf("%d", &n) != 1) return 0;

    int in[n], post[n];
    for (int i = 0; i < n; i++) scanf("%d", &in[i]);
    for (int i = 0; i < n; i++) scanf("%d", &post[i]);

    int postIdx = n - 1;
    struct Node* root = buildTree(in, post, 0, n - 1, &postIdx);

    printPreorder(root);
    printf("\n");

    return 0;
}
