#include <stdio.h>

#define MAX 100000
#define OFFSET 50000

int main() {
    int n;
    scanf("%d", &n);

    int arr[MAX];

    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // To store first occurrence of prefix sums
    int index[2 * MAX];
    for (int i = 0; i < 2 * MAX; i++)
        index[i] = -2;

    int prefixSum = 0;
    int maxLen = 0;

    // prefix sum = 0 occurs at index -1
    index[OFFSET] = -1;

    for (int i = 0; i < n; i++) {
        prefixSum += arr[i];

        int key = prefixSum + OFFSET;

        if (index[key] == -2) {
            // first time seen
            index[key] = i;
        } else {
            // repeated prefix sum → subarray sum = 0
            int len = i - index[key];
            if (len > maxLen)
                maxLen = len;
        }
    }

    printf("%d\n", maxLen);

    return 0;
}
