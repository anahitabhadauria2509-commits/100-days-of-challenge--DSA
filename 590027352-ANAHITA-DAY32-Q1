Problem: Implement push and pop operations on a stack and verify stack operations

#include <stdio.h>

int main() {
    int n, m, val;
    int stack[100], top = -1;

    // 1. Push n elements
    if (scanf("%d", &n) != 1) return 0;
    for (int i = 0; i < n; i++) {
        scanf("%d", &val);
        stack[++top] = val;
    }

    // 2. Pop m elements
    if (scanf("%d", &m) != 1) return 0;
    while (m-- > 0 && top >= 0) {
        top--;
    }

    // 3. Display remaining (top to bottom)
    for (int i = top; i >= 0; i--) {
        printf("%d%s", stack[i], (i == 0) ? "" : " ");
    }
    printf("\n");

    return 0;
}
