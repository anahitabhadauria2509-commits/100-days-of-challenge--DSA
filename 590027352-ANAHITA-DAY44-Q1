Problem Statement:
Perform inorder, preorder, and postorder traversals of a given binary tree.


#include <stdio.h>

// 1. Inorder: Left -> Root -> Right
void inorder(int arr[], int n, int i) {
    if (i >= n || arr[i] == -1) return;
    inorder(arr, n, 2 * i + 1);
    printf("%d ", arr[i]);
    inorder(arr, n, 2 * i + 2);
}

// 2. Preorder: Root -> Left -> Right
void preorder(int arr[], int n, int i) {
    if (i >= n || arr[i] == -1) return;
    printf("%d ", arr[i]);
    preorder(arr, n, 2 * i + 1);
    preorder(arr, n, 2 * i + 2);
}

// 3. Postorder: Left -> Right -> Root
void postorder(int arr[], int n, int i) {
    if (i >= n || arr[i] == -1) return;
    postorder(arr, n, 2 * i + 1);
    postorder(arr, n, 2 * i + 2);
    printf("%d ", arr[i]);
}

int main() {
    int n;
    if (scanf("%d", &n) != 1) return 0;

    int arr[n];
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Call all three traversals starting from root (index 0)
    inorder(arr, n, 0);   printf("\n");
    preorder(arr, n, 0);  printf("\n");
    postorder(arr, n, 0); printf("\n");

    return 0;
}
