#include <stdio.h>
#include <stdlib.h>

#define MAX 1000

typedef struct {
    int start;
    int end;
} Meeting;

int heap[MAX];
int size = 0;

// Min-heap functions
void swap(int *a, int *b) {
    int temp = *a;
    *a = *b;
    *b = temp;
}

void push(int val) {
    int i = size++;
    heap[i] = val;

    while (i > 0 && heap[(i - 1) / 2] > heap[i]) {
        swap(&heap[i], &heap[(i - 1) / 2]);
        i = (i - 1) / 2;
    }
}

void heapify(int i) {
    int smallest = i;
    int l = 2 * i + 1;
    int r = 2 * i + 2;

    if (l < size && heap[l] < heap[smallest])
        smallest = l;

    if (r < size && heap[r] < heap[smallest])
        smallest = r;

    if (smallest != i) {
        swap(&heap[i], &heap[smallest]);
        heapify(smallest);
    }
}

int pop() {
    int root = heap[0];
    heap[0] = heap[--size];
    heapify(0);
    return root;
}

// Sort by start time
int compare(const void *a, const void *b) {
    return ((Meeting *)a)->start - ((Meeting *)b)->start;
}

int main() {
    int n;
    scanf("%d", &n);

    Meeting arr[n];

    for (int i = 0; i < n; i++) {
        scanf("%d %d", &arr[i].start, &arr[i].end);
    }

    // Sort meetings by start time
    qsort(arr, n, sizeof(Meeting), compare);

    size = 0;

    // Add first meeting end time
    push(arr[0].end);

    for (int i = 1; i < n; i++) {

        // If room is free (earliest end <= current start)
        if (heap[0] <= arr[i].start) {
            pop(); // reuse room
        }

        // allocate room (new or reused)
        push(arr[i].end);
    }

    printf("%d\n", size);

    return 0;
}
