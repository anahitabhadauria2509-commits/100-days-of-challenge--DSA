#include <stdio.h>
#include <stdlib.h>
#include <stdbool.h>

struct Node {
    int data;
    struct Node *left, *right;
};

struct Node* newNode(int val) {
    if (val == -1) return NULL;
    struct Node* temp = (struct Node*)malloc(sizeof(struct Node));
    temp->data = val;
    temp->left = temp->right = NULL;
    return temp;
}

// Zigzag Traversal using two stacks
void printZigzag(struct Node* root, int n) {
    if (!root) return;

    // Two stacks: current level and next level
    struct Node** s1 = (struct Node**)malloc(sizeof(struct Node*) * n);
    struct Node** s2 = (struct Node**)malloc(sizeof(struct Node*) * n);
    int top1 = -1, top2 = -1;

    s1[++top1] = root;
    bool leftToRight = true;

    while (top1 != -1) {
        while (top1 != -1) {
            struct Node* curr = s1[top1--];
            printf("%d ", curr->data);

            if (leftToRight) {
                if (curr->left) s2[++top2] = curr->left;
                if (curr->right) s2[++top2] = curr->right;
            } else {
                if (curr->right) s2[++top2] = curr->right;
                if (curr->left) s2[++top2] = curr->left;
            }
        }
        // Swap stacks and flip direction
        struct Node** tempStack = s1;
        s1 = s2;
        s2 = tempStack;
        top1 = top2;
        top2 = -1;
        leftToRight = !leftToRight;
    }
    free(s1);
    free(s2);
}

int main() {
    int n;
    if (scanf("%d", &n) != 1) return 0;
    int *arr = (int*)malloc(sizeof(int) * n);
    for (int i = 0; i < n; i++) scanf("%d", &arr[i]);

    // Build tree from level-order input
    struct Node* root = newNode(arr[0]);
    struct Node** q = (struct Node**)malloc(sizeof(struct Node*) * n);
    int head = 0, tail = 0;
    if (root) q[tail++] = root;

    int i = 1;
    while (i < n && head < tail) {
        struct Node* curr = q[head++];
        if (i < n) {
            curr->left = newNode(arr[i++]);
            if (curr->left) q[tail++] = curr->left;
        }
        if (i < n) {
            curr->right = newNode(arr[i++]);
            if (curr->right) q[tail++] = curr->right;
        }
    }

    printZigzag(root, n);
    printf("\n");

    return 0;
}
