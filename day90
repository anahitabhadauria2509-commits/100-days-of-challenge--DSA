#include <stdio.h>

int arr[1000];

int isPossible(int n, int k, int maxTime) {
    int painters = 1;
    int timeSum = 0;

    for (int i = 0; i < n; i++) {

        if (arr[i] > maxTime)
            return 0;

        if (timeSum + arr[i] > maxTime) {
            painters++;
            timeSum = arr[i];

            if (painters > k)
                return 0;
        } else {
            timeSum += arr[i];
        }
    }

    return 1;
}

int main() {
    int n, k;
    scanf("%d %d", &n, &k);

    int sum = 0, maxBoard = 0;

    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
        sum += arr[i];

        if (arr[i] > maxBoard)
            maxBoard = arr[i];
    }

    int low = maxBoard;
    int high = sum;
    int ans = -1;

    while (low <= high) {
        int mid = (low + high) / 2;

        if (isPossible(n, k, mid)) {
            ans = mid;
            high = mid - 1;   // try smaller time
        } else {
            low = mid + 1;
        }
    }

    printf("%d\n", ans);

    return 0;
}
