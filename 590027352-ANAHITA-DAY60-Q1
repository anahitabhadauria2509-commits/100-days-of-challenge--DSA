#include <stdio.h>
#include <stdbool.h>

bool isMinHeap(int arr[], int n) {
    // Only need to check nodes that have at least one child
    for (int i = 0; i <= (n - 2) / 2; i++) {
        
        // Check left child
        int left = 2 * i + 1;
        if (left < n && arr[i] > arr[left]) {
            return false;
        }

        // Check right child
        int right = 2 * i + 2;
        if (right < n && arr[i] > arr[right]) {
            return false;
        }
    }
    return true;
}

int main() {
    int n;
    if (scanf("%d", &n) != 1) return 0;

    int arr[n];
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    if (isMinHeap(arr, n)) {
        printf("YES\n");
    } else {
        printf("NO\n");
    }

    return 0;
}
