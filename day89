#include <stdio.h>

int arr[1000];

int isPossible(int n, int m, int maxPages) {
    int students = 1;
    int pagesSum = 0;

    for (int i = 0; i < n; i++) {
        if (arr[i] > maxPages)
            return 0;

        if (pagesSum + arr[i] > maxPages) {
            students++;
            pagesSum = arr[i];

            if (students > m)
                return 0;
        } else {
            pagesSum += arr[i];
        }
    }

    return 1;
}

int main() {
    int n, m;
    scanf("%d %d", &n, &m);

    int sum = 0, maxBook = 0;

    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
        sum += arr[i];

        if (arr[i] > maxBook)
            maxBook = arr[i];
    }

    int low = maxBook;
    int high = sum;
    int ans = -1;

    while (low <= high) {
        int mid = (low + high) / 2;

        if (isPossible(n, m, mid)) {
            ans = mid;
            high = mid - 1;   // try smaller max
        } else {
            low = mid + 1;
        }
    }

    printf("%d\n", ans);

    return 0;
}
