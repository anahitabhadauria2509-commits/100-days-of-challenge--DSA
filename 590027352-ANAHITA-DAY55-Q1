#include <stdio.h>
#include <stdlib.h>

struct Node {
    int data;
    struct Node *left, *right;
};

struct Node* newNode(int val) {
    if (val == -1) return NULL;
    struct Node* temp = (struct Node*)malloc(sizeof(struct Node));
    temp->data = val;
    temp->left = temp->right = NULL;
    return temp;
}

// Global variable or pointer to keep track of the maximum level visited
int max_level = 0;

// Core Logic: Recursive Right View Traversal
// We visit Right children before Left children and keep track of depth
void rightView(struct Node* root, int level) {
    if (root == NULL) return;

    // If this is the first time we've reached this level, it's the rightmost node
    if (max_level < level) {
        printf("%d ", root->data);
        max_level = level;
    }

    // Traverse right subtree first to prioritize right-side visibility
    rightView(root->right, level + 1);
    rightView(root->left, level + 1);
}

int main() {
    int n;
    if (scanf("%d", &n) != 1) return 0;
    int *arr = (int*)malloc(sizeof(int) * n);
    for (int i = 0; i < n; i++) scanf("%d", &arr[i]);

    // Standard Level-order Tree Construction
    struct Node* root = newNode(arr[0]);
    struct Node** q = (struct Node**)malloc(sizeof(struct Node*) * n);
    int head = 0, tail = 0;
    if (root) q[tail++] = root;

    int i = 1;
    while (i < n && head < tail) {
        struct Node* curr = q[head++];
        if (i < n) {
            curr->left = newNode(arr[i++]);
            if (curr->left) q[tail++] = curr->left;
        }
        if (i < n) {
            curr->right = newNode(arr[i++]);
            if (curr->right) q[tail++] = curr->right;
        }
    }

    rightView(root, 1);
    printf("\n");

    free(arr);
    free(q);
    return 0;
}
