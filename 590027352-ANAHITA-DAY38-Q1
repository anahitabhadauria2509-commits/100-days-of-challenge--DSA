Problem: Deque (Double-Ended Queue)

#include <stdio.h>

#define MAX 5

int deque[MAX];
int front = -1, rear = -1, size = 0;

void push_back(int val) {
    if (size == MAX) { printf("Full\n"); return; }
    if (front == -1) front = 0;
    rear = (rear + 1) % MAX; // Move rear forward
    deque[rear] = val;
    size++;
}

void push_front(int val) {
    if (size == MAX) { printf("Full\n"); return; }
    if (front == -1) { front = 0; rear = 0; }
    else front = (front - 1 + MAX) % MAX; // Move front backward
    deque[front] = val;
    size++;
}

int pop_front() {
    if (size == 0) return -1;
    int val = deque[front];
    front = (front + 1) % MAX;
    size--;
    return val;
}

void display() {
    for (int i = 0; i < size; i++) {
        printf("%d ", deque[(front + i) % MAX]);
    }
    printf("\n");
}

int main() {
    push_back(10);
    push_back(20);
    push_front(5);
    
    display(); // Output: 5 10 20
    
    pop_front();
    display(); // Output: 10 20
    
    return 0;
}
