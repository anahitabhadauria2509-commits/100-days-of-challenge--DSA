Problem Statement:
Implement a Min Heap using an array where the smallest element is always at the root.


#include <stdio.h>
#include <string.h>

int heap[1000], size = 0;

void swap(int *a, int *b) {
    int t = *a; *a = *b; *b = t;
}

void insert(int x) {
    int i = size++;
    heap[i] = x;
    while (i > 0 && heap[i] < heap[(i - 1) / 2]) {
        swap(&heap[i], &heap[(i - 1) / 2]);
        i = (i - 1) / 2;
    }
}

void extractMin() {
    if (size == 0) { printf("-1\n"); return; }
    printf("%d\n", heap[0]);
    heap[0] = heap[--size];
    int i = 0;
    while (2 * i + 1 < size) {
        int small = 2 * i + 1;
        if (small + 1 < size && heap[small + 1] < heap[small]) small++;
        if (heap[i] <= heap[small]) break;
        swap(&heap[i], &heap[small]);
        i = small;
    }
}

int main() {
    int n, val;
    char op[20];
    scanf("%d", &n);
    while (n--) {
        scanf("%s", op);
        if (strcmp(op, "insert") == 0) {
            scanf("%d", &val);
            insert(val);
        } else if (strcmp(op, "extractMin") == 0) {
            extractMin();
        } else if (strcmp(op, "peek") == 0) {
            printf("%d\n", size > 0 ? heap[0] : -1);
        }
    }
    return 0;
}
