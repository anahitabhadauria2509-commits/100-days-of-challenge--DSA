#include <stdio.h>
#include <string.h>

#define MAX 100
#define EMPTY -1

int table[MAX];
int m;  // size of hash table

// Insert key using quadratic probing
void insert(int key) {
    int i = 0;
    int index;

    while (i < m) {
        index = (key % m + i * i) % m;

        if (table[index] == EMPTY) {
            table[index] = key;
            return;
        }
        i++;
    }

    printf("Hash table is full, cannot insert %d\n", key);
}

// Search key using quadratic probing
int search(int key) {
    int i = 0;
    int index;

    while (i < m) {
        index = (key % m + i * i) % m;

        if (table[index] == EMPTY)
            return 0; // NOT FOUND

        if (table[index] == key)
            return 1; // FOUND

        i++;
    }

    return 0;
}

int main() {
    int n;
    scanf("%d", &m);  // table size
    scanf("%d", &n);  // number of operations

    // Initialize table
    for (int i = 0; i < m; i++)
        table[i] = EMPTY;

    char op[10];
    int key;

    for (int i = 0; i < n; i++) {
        scanf("%s %d", op, &key);

        if (strcmp(op, "INSERT") == 0) {
            insert(key);
        } else if (strcmp(op, "SEARCH") == 0) {
            if (search(key))
                printf("FOUND\n");
            else
                printf("NOT FOUND\n");
        }
    }

    return 0;
}
